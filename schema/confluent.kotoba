// Confluent clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace confluent {

    entity Connector {
        id: string @unique
        name: string
        source: string
        destination: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Sync {
        id: string @unique
        connectorId: string
        status: string
        rows: integer
        startedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Model {
        id: string @unique
        name: string
        materialization: string
        sql: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Stream {
        id: string @unique
        name: string
        partitions: integer
        retentionMs: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Schema {
        id: string @unique
        name: string
        database: string
        tableCount: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Test {
        id: string @unique
        modelName: string
        type: string
        passed: boolean
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
